    <script>
        var nameArr = ["林大明", "陳小華", "林大明", "林小美", "陳曉潔", "林大明", "陳小華", "林大明", "林小美", "陳曉潔", "林大明", "陳小華", "林大明", "林小美", "陳曉潔", "林大明", "陳小華", "林大明", "林小美", "陳曉潔"];
        var idArr = ["AreaPei", "AreaTao", "AreaChung", "AreaNam", "AreaKao"];

        var fragment = document.createDocumentFragment();
        var addButton = document.querySelector("button");

        function buildItem() {
            // var i = [];
            let randomColor = (
                "000000" + Math.floor(Math.random() * 16777215).toString(16)
            ).slice(-6);
            let BuildArea = document.querySelectorAll('.teachers-list-items-small-areas-cnt');
            BuildArea.forEach(function (item, i) {
                let randomNum = Math.floor(Math.random() * 100) + 1;
                let apiUrl = 'https://avatars.dicebear.com/api/pixel-art/s';
                let Url = apiUrl + randomNum + i + ".svg?background=%23" + randomColor + '&mood[]=sad&mood[]=happy"';
                let li = document.createElement("li");
                li.className = "teachers-list-small-item";
                let Html = `<div class="teachers-list-small-item-avatar">
                                        <img alt="avatar" src="${Url}">
                                    </div>
                                    <div class="teachers-list-small-item-cnt ">
                                        <div>林大明</div>
                                    </div>`;
                li.innerHTML = Html;
                fragment.appendChild(li);
                let gridView = document.getElementById(idArr[i]);
                // console.log(gridView)
                gridView.querySelector('ul').append(fragment);
                observeriConLi("li");
            });
        }

        // 觀察元素是否進入視窗範圍
        function observeriConLi(items) {
            if (
                !("IntersectionObserver" in window) &&
                !("IntersectionObserverEntry" in window) &&
                !("intersectionRatio" in window.IntersectionObserverEntry.prototype)
            ) {
                return;
            }

            var elementsToLoadIn = document.querySelectorAll(items);
            elementsToLoadIn.forEach(function (el) {
                el.classList.add("an-loadin");
            });
            var observerOptions = {
                root: null,
                rootMargin: "0px 0px 0px 0px",
                threshold: 0
            };

            function observerCallback(entries) {
                entries.forEach(function (entry) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("an-loaded");
                        observer.unobserve(entry.target); // 停止觀察
                    }
                });
            }

            var observer = new IntersectionObserver(observerCallback, observerOptions);
            elementsToLoadIn.forEach(function (el) {
                return observer.observe(el);
            });
        }

        //DOMContentLoaded
        //document.addEventListener("DOMContentLoaded", function () {
        //    for (var i = 0; i < 24 + 1; i++) {
        //        window.requestAnimationFrame(buildItem);
        //    }
        //});

        // 建立右側卡片導航
        const CardNavBuild = new JsBuildSideNav('.t-course-card-title', {
            nav: 'listenList',
            navClass: 'observer-nav',
            navTag: 'div',
            navItemTag: 'a',
            navItemClass: 'observer-nav-item',
            navItemClasPre: ["pei", "tao", "chung", "nam", "kao", "ano"]
        });

        const floatObserver = new JsScrollStickyObserver("listenList", {
            prevElementID: "hrLine",
            stopElementID: "mainFooter",
            fixedClassName: "is-fix",
            stopClassName: "is-absolute",
            callback: {
                root: "tCourseCotent",
                rootMargin: '200px',
                threshold: [1, 0.5, 0]
            }
        });


        window.addEventListener("load", function (event) {

        });
    </script>
