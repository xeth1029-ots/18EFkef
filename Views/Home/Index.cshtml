@*<script src="./index.js"></script>*@
<script type="text/javascript">
    function doSwiper() {
        $("#owlcarousel_swiper").owlCarousel({
            margin: 10,
            loop: true,
            autoWidth: true,
            center: true,
            dots: true,
            nav: true,
            navText: [
                '<i title="向左滑動" class="glyphicon glyphicon-chevron-left"></i><span class="sr-only">向左滑動<span>',
                '<i title="向右滑動" class="glyphicon glyphicon-chevron-right"></i><span class="sr-only">向右滑動<span>'
            ],
            responsive: { 0: { items: 2, }, 768: { items: 3, }, 992: { items: 4, }, },
            responsiveClass: true,
            mouseDrag: false,
            touchDrag: false,
            pullDrag: false,
            autoplay: true,
            autoplayHoverPause: true,
            autoplayTimeout: 6000,
            autoplaySpeed: 2500,
        });

        $("#owlcarousel_teachers").owlCarousel({
            margin: 0,
            loop: true,
            autoWidth: true,
            center: true,
            dots: true,
            nav: true,
            navText: [
                '<i title="向左滑動" class="glyphicon glyphicon-chevron-left"></i><span class="sr-only">向左滑動<span>',
                '<i title="向右滑動" class="glyphicon glyphicon-chevron-right"></i><span class="sr-only">向右滑動<span>'
            ],
            responsive: { 0: { items: 2, }, 768: { items: 3, }, 992: { items: 4, }, },
            responsiveClass: true,
            mouseDrag: false,
            touchDrag: false,
            pullDrag: false,
            autoplay: true,
            autoplayHoverPause: true,
            autoplayTimeout: 5000,
            autoplaySpeed: 2500,
        });

        $('.owl-carousel').on('changed.owl.carousel', function (event) {
            $(this).find('.owl-nav').removeClass('disabled');
            $(this).find('.owl-dots').removeClass('disabled');
        });
        $('.owl-carousel').find('.owl-nav').removeClass('disabled');
        $('.owl-carousel').find('.owl-dots').removeClass('disabled');

        let Last = "";  // Last id name
        let Idx = 1;    // Title index
        //"(There are currently no events, please stay tuned!)"
        var s_staytuned = "(目前暫無活動，敬請期待!)";
        document.getElementsByClassName("owl-dot").forEach(function (e) {
            if (Last === "") { Last = e.parentElement.parentElement.id; }
            if (Last === e.parentElement.parentElement.id) {
                // Create title string
                let tmpStr = "";
                if (e.parentElement.parentElement.id === "owlcarousel_swiper") { tmpStr = "第" + Idx + "張" + s_staytuned; }
                if (e.parentElement.parentElement.id === "owlcarousel_teachers") { tmpStr = "第" + Idx + "位"; }
                // Add title
                e.setAttribute("title", tmpStr);
                Idx++;
            }
            else {
                // Reset
                Last = e.parentElement.parentElement.id;
                Idx = 1;
                // Create title string
                let tmpStr = "";
                if (e.parentElement.parentElement.id === "owlcarousel_swiper") { tmpStr = "第" + Idx + "張" + s_staytuned; }
                if (e.parentElement.parentElement.id === "owlcarousel_teachers") { tmpStr = "第" + Idx + "位"; }
                // Add title
                e.setAttribute("title", tmpStr);
                Idx++;
            }
        });
    }

    //$(function () { });

    $(document).ready(function () {
        setTimeout("doSwiper()", 1500);
        $("#owlPlay").attr("aria-pressed", "true");
        $("#owlStop").attr("aria-pressed", "false");
    });

    //新增控制列
    var owlSwiper = $("#owlcarousel_swiper");

    $("#owlPlay").on("click", function () {
        owlSwiper.trigger("play.owl.autoplay", [5000]);
        $("#owlPlay").attr("aria-pressed", "true");
        $("#owlStop").attr("aria-pressed", "false");
    });

    $("#owlStop").on("click", function () {
        owlSwiper.trigger("stop.owl.autoplay");
        $("#owlPlay").attr("aria-pressed", "false");
        $("#owlStop").attr("aria-pressed", "true");
    });

    // 詳細資料
    function doNewsDetail(Seq) {
        var data = { "Seq": Seq }
        var url = "@Url.Action("NewsDetail", "C102M", new { area = "A1" })" + "?" + $.param(data);
        window.open(url, '_blank');
    }

</script>