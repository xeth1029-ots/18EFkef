</style>

<!-- Hero -->
<section class="t-hero">
    <div class="container">
        <div class="t-flex flex-column flex-md-row align-items-center justify-content-sm-between">
            <!-- swiper -->
            <div class="col-12 col-md-7">
                <div class="js-swiper-hero swiper">
                    <div class="swiper-wrapper">
                        <ul class="banner-list banner-list-fixed owl-carousel owl-theme" id="owlcarousel_swiper">
                            <li>
                                <div class="swiper-slide">
                                    <img class="img-fluid my-div-space22" src="@Url.Content(jpg_slider_v1)" alt="" />
                                </div>
                            </li>
                            <li>
                                <div class="swiper-slide">
                                    <img class="img-fluid my-div-space22" src="@Url.Content(jpg_slider_v2)" alt="" />
                                </div>
                            </li>
                            @* <li><div class="swiper-slide"><img class="img-fluid my-div-space22" src="@Url.Content(jpg_slider_v3)" alt=""></div></li> *@
                        </ul>
                    </div>
                </div>
                @* 20251218 新增播放控制器 *@
                <div class="owl-controls-wrapper">
                    @*<button type="button"class="owl-prev-custom btn btn-sm btn-outline-secondary"aria-label="上一張"><i class="fas fa-backward"></i></button>*@
                    <button type="button" id="owlPlay" class="btn btn-sm btn-outline-primary" aria-label="播放輪播" title="播放輪播">
                        <i class="fas fa-play"></i>
                    </button>
                    <button type="button" id="owlStop" class="btn btn-sm btn-outline-secondary" aria-label="暫停輪播" title="暫停輪播">
                        <i class="fas fa-stop"></i>
                    </button>
                   @*<button type="button"class="owl-next-custom btn btn-sm btn-outline-secondary"aria-label="下一張"><i class="fas fa-forward"></i></button>*@
                </div>
            </div>
            <!-- search -->
            <div class="col-12 col-md-5">
                <figure class="t-absolute w-48 h-32 t-tp-6 t-rt-12 opt-48">
                    <img class="img-fluid" src="@Url.Content(svg_curved_55)" alt="">
                </figure>
                <div class="t-hero-search">
                    <form id="main_form" action="~/A1/C101M/Index" method="post" class="t-form t-form-input-field">
                        <legend class="t-form-legend-secondary t-absolute t-lt-1 t-tp--3 teacher-search-legend">師資搜尋</legend>
                        <picture class="t-hero-search-imgs">
                            <source src="@Url.Content(png_heroimg_1)" data-src="@Url.Content(svg10Ratio3)">
                            <img src="@Url.Content(png_heroimg_1)" alt="">
                        </picture>
                        @*<input id="hid_TeachArea" name="TeachArea" type="hidden" class="t-form-control" placeholder="授課區域" title="師資搜尋授課區域">
                            <input id="hid_LiveArea" name="LiveArea" type="hidden" class="t-form-control" placeholder="居住地" title="師資搜尋居住地">*@
                        <div class="t-form-group">
                            <label for="s_keyWordr">關鍵字</label>
                            <input id="s_keyWordr" name="Keyword" type="text" class="t-form-control" placeholder="姓名 (中、英文)、專長 / 領域" title="師資搜尋關鍵字：姓名 (中、英文)、專長 / 領域">
                        </div>
                        <div class="t-form-inline">
                            <div class="t-form-group">
                                <label for="TeachUnit">授課單元</label>
                                @Html.DropDownList("TeachUnit", TeachUnit_list, new { @class = "t-form-control", style = "width:100%", title = "師資搜尋授課單元" })
                            </div>
                            <div class="t-form-group">
                                <label for="Industry">授課產業別</label>
                                @Html.DropDownList("Industry", Industry_list, new { @class = "t-form-control", style = "width:100%", title = "師資搜尋授課產業別" })
                            </div>
                        </div>
                        <div class="t-form-inline">
                            <div class="t-form-group">
                                <label for="ddlTeachArea">授課區域</label>
                                @Html.DropDownList("ddlTeachArea", City_list1, new { @class = "t-form-control", style = "width:100%", title = "師資搜尋授課區域" })
                            </div>
                            <div class="t-form-group">
                                <label for="ddlLiveArea">居住地</label>
                                @Html.DropDownList("ddlLiveArea", City_list2, new { @class = "t-form-control", style = "width:100%", title = "師資搜尋居住地" })
                            </div>
                        </div>
                        @*
                            <div class="t-form-inline">
                            <div class="t-form-group"><label for="s_areaPicker1">授課區域</label>
                            <input id="s_areaPicker1" name="TeachArea" type="text" class="t-form-control" placeholder="授課區域" title="師資搜尋授課區域"></div>
                            <div class="t-form-group"><label for="s_areaPicker2">居住地</label>
                            <input id="s_areaPicker2" name="LiveArea" type="text" class="t-form-control" placeholder="居住地" title="師資搜尋居住地"></div></div>
                        *@
                        <div class="t-form-group mb-0">
                            <button type="submit" class="t-hero-search-btn btn btn--primary btn--block btn--lg" title="點擊以搜尋師資">
                                <i class="svg-icon svg-icon-2hx t-v-align-bottom" aria-hidden="true">
                                    <svg>
                                        <use href="#ic-search"></use>
                                    </svg>
                                </i>
                                搜尋師資
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
