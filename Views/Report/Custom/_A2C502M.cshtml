@using System.Collections;
@using WKEFSERVICE.Models;
@using WKEFSERVICE.Commons;
@using WKEFSERVICE.Services;
@model Report
@{
    Layout = null;
}

<style>
    .RptPage {
        page-break-after: always;
    }

