            font-size: 24pt;
            font-family: 標楷體;
            font-weight: bold;
            text-align: center;
        }

        .RptPage .content {
            width: 100%;
            font-size: 22pt;
            font-family: 標楷體;
            text-align: center;
        }

        .RptPage .memo {
            width: 100%;
            font-size: 14pt;
            font-family: 標楷體;
            text-align: left;
        }

        .RptPage .myfooter {
            width: 100%;
            font-size: 24pt;
            font-family: 標楷體;
            text-align: right;
        }

        .RptPage .ident {
            padding-left: 0px;
