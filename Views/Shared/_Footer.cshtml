    //@Url.Content(svglogobg)
    string svglogobg = "~/assets_new/images/wda_logo_bg.svg";
    //@Url.Content(svglogocircle)
    string svglogocircle = "~/assets_new/images/wda_logo_circle.svg";
    // 無障礙-首頁抬頭文字
    string s_MainTitle = "勞動部勞動力發展署-關鍵就業力課程";
    string s_DepWorkAddress = "24219 新北市新莊區中平路 439 號 (南棟 4 樓)";
    string s_TelRepnumber = "(02)8995-6000";
    // 移除//string s_supporthotline1 = "(03)6210160";  //string s_supporthotline2 = "(03)6210163";
    string s_supporthotline3 = "(03)564-0958分機23、24";
    string s_OurServiceHours = "週一～週五 08:30～12:30、13:30～17:30";
    //隱私權及資訊安全政策 /隱私權及安全政策
    ViewBag.Url_Privacy1 = "https://www.wda.gov.tw/cp.aspx?n=13";

}

<footer class="t-custom-footer" id="mainFooter">
    <div class="container">
        <div class="row align-items-center pb-4">
            <div class="col-md">
                <div class="t-custom-footer-logo">
                    <picture class="opt-36">
                        <source class="" src="@Url.Content(svglogobg)" data-src="@Url.Content(svg10Ratio3)">
                        <img alt="@s_MainTitle" src="@Url.Content(svglogobg)" />
                    </picture>
                </div>
            </div>
        </div>
        <div class="t-custom-footer-bd pb-4">
            <div class="row">
                <div class="col-sm-3">
                    <ul class="list-unstyled t-footer-list">
                        <li>
                            <a href="#L" title="下方功能區塊, 快速鍵: Alt+L " id="AL" accesskey="L" name="L" class="quicklink t-header-top-list-link">:::</a>
                            <a class="link link-light" href="~/Home/SiteGuide" title="前往網站導覽">網站導覽</a>
