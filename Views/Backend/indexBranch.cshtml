<script type="text/javascript">

    // 查看會議內容
    function doViewMeeting(Seq) {
        var data = { "Seq": Seq }
        var url = "@ConfigModel.WKEF/A3/C401M/Detail?" + $.param(data);
        window.open(url, '_blank');
    }

    // 查看會議名單
    function doViewSignUpList(Seq) {
        var data = { "Seq": Seq }
        var url = "@ConfigModel.WKEF/A3/C401M/DetailSignUp?" + $.param(data);
        window.open(url, '_blank');
    }

    // 查看自我審核報告
    function doViewAuditReports(Seq) {
        var data = { "Seq": Seq }
        var url = "@ConfigModel.WKEF/A3/C204M/Audit?" + $.param(data);
        window.open(url, '_blank');
    }

    // 立即報名
    function doHomeSignUp(MeetingSeq) {
        alert("身分不符");
    }

    // 授課推廣 查看明細
    function A3C205MView(typeA, typeB) {
        //console.log(typeA + ',' + typeB);
        var data = { "PlanTypeCode": typeA, "JobAbilityCode": typeB };
        var url = "@ConfigModel.WKEF/A3/C205M/IndexFromHome?" + $.param(data);
        window.open(url, '_blank');
    }

</script>