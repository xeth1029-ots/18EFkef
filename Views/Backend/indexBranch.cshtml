@using WKEFSERVICE.Models
@using WKEFSERVICE.Models.Entities
@using WKEFSERVICE.Services
@using WKEFSERVICE.DataLayers
@model WKEFSERVICE.Models.HomeModel
@{
    Layout = "~/Views/Backend/_BackendMainLayout.cshtml";

    // 去抓取最新消息資料，預設 5 筆
    var tmpRtnObj1 = new WKEFSERVICE.Controllers.BackendController().GetNewsDatas("", "3");
    var tmpNewsModelObj = (HomeModel)tmpRtnObj1.GetType().GetProperty("Model").GetValue(tmpRtnObj1, null);

    // 去抓取會議資料，預設 5 筆
    var tmpRtnObj2 = new WKEFSERVICE.Controllers.BackendController().GetMeetingsDatas("2");
    var tmpMeetingsModelObj = (HomeModel)tmpRtnObj2.GetType().GetProperty("Model").GetValue(tmpRtnObj2, null);

    // 去抓取自我審核報告，取前 4 筆
    var tmpRtnObj3 = new WKEFSERVICE.Controllers.BackendController().GetAuditReportsDatas("S");
    var tmpAuditReportsModelObj = (HomeModel)tmpRtnObj3.GetType().GetProperty("Model").GetValue(tmpRtnObj3, null);
    string C204MCount = tmpAuditReportsModelObj.AuditReportsGrid.ToCount().ToString();
    tmpAuditReportsModelObj.AuditReportsGrid = tmpAuditReportsModelObj.AuditReportsGrid.Take(4).ToList();
}

<section class="bt-section">
