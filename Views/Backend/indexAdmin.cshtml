    }

    // 授課推廣 查看明細
    function AMC202MView(typeA, typeB) {
        //console.log(typeA + ',' + typeB);
        var data = { "PlanTypeCode": typeA, "JobAbilityCode": typeB };
        var url = "@ConfigModel.WKEF/AM/C202M/IndexFromHome?" + $.param(data);
        window.open(url, '_blank');
    }

</script>