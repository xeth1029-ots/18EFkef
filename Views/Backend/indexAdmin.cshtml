<script type="text/javascript">

    // 查看會議內容
    function doViewMeeting(Seq) {
        var data = { "Seq": Seq }
        var url = "@ConfigModel.WKEF/AM/C301M/Detail?" + $.param(data);
        window.open(url, '_blank');
    }

    // 查看會議名單
    function doViewSignUpList(Seq) {
        var data = { "Seq": Seq }
        var url = "@ConfigModel.WKEF/AM/C301M/DetailSignUp?" + $.param(data);
        window.open(url, '_blank');
    }

    // 查看自我審核報告
    function doViewAuditReports(Seq) {
        var data = { "Seq": Seq }
        var url = "@ConfigModel.WKEF/AM/C902M/Audit?" + $.param(data);
        window.open(url, '_blank');
