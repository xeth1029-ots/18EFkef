                            <i class="svg-icon svg-icon-2x" aria-hidden="true">
                                <svg>
                                    <use href="#ic-diamond"></use>
                                </svg>
                            </i>
                            <div class="t-panel-heading-txt" data-title="SKILLS">職能類別</div>
                        </div>
                        <div class="t-panel-main">
                            <div class="t-panel-main-fuild">
                                <div class="t-label-list flex-row">
                                    @if (Model.Detail.TeachJobAbilityKC.TONotNullString() == "Y")
                                    {
                                        <label class="t-badge t-badge-light-secondary" data-bs-toggle="tooltip" title="飛航、服務、管理就業學程" aria-label="飛航、服務、管理就業學程" data-bs-placement="top">
                                            知識職能 (KC)
                                        </label>
                                    }
                                    @if (Model.Detail.TeachJobAbilityBC.TONotNullString() == "Y")
                                    {
                                        <label class="t-badge t-badge-light-warning" data-bs-toggle="tooltip" title="飛航、服務、管理就業學程" aria-label="飛航、服務、管理就業學程" data-bs-placement="top">
                                            行為職能 (BC)
                                        </label>
                                    }
                                    @if (Model.Detail.TeachJobAbilityDC.TONotNullString() == "Y")
                                    {
                                        <label class="t-badge t-badge-light-primary" data-bs-toggle="tooltip" title="飛航、服務、管理就業學程" aria-label="飛航、服務、管理就業學程" data-bs-placement="top">
                                            動機職能 (DC)
                                        </label>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- 職能類別 End -->
                <!-- 授課區域 Start -->
                <a name="academic_teacharea" id="academic_teacharea"></a>
                <div id="TeachArea" class="t-info-item" data-profile="academic_teacharea">
                    <div class="t-panel bt-section-search">
                        <div class="t-panel-heading">
                            <i class="svg-icon svg-icon-2x" aria-hidden="true">
                                <svg>
                                    <use href="#ic-map"></use>
                                </svg>
                            </i>
                            <div class="t-panel-heading-txt" data-title="TEACH AREA">授課區域</div>
                        </div>
                        <div class="t-panel-main">
                            <div class="t-panel-main-fuild" style="word-wrap: break-word; white-space: pre-line;">
                                <div class="t-para">@Model.Detail.TeachArea_Name</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- 授課區域 End -->
                <!-- 授課產業別 Start -->
                <a name="academic_teachindustry" id="academic_teachindustry"></a>
                <div id="TeachIndustry" class="t-info-item" data-profile="academic_teachindustry">
                    <div class="t-panel bt-section-search">
                        <div class="t-panel-heading">
                            <i class="svg-icon svg-icon-2x" aria-hidden="true">
                                <svg>
                                    <use href="#ic-map"></use>
                                </svg>
                            </i>
                            <div class="t-panel-heading-txt" data-title="TEACH INDUSTRY">授課產業別</div>
                        </div>
                        <div class="t-panel-main">
                            <div class="t-panel-main-fuild" style="word-wrap: break-word; white-space: pre-line;">
                                <div class="t-para">@Model.Detail.Industry_Name</div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- 授課產業別 End -->
                <!-- 產學類別 Start -->
                <a name="academic_IndustryAcademicType" id="academic_IndustryAcademicType"></a>
                <div id="IndustryAcademicType" class="t-info-item" data-profile="academic_IndustryAcademicType">
                    <div class="t-panel bt-section-search">
                        <div class="t-panel-heading">
                            <i class="svg-icon svg-icon-2x" aria-hidden="true">
                                <svg>
                                    <use href="#ic-location"></use>
                                </svg>
                            </i>
                            <div class="t-panel-heading-txt" data-title="INDUSTRY ACADEMIC">產學類別</div>
                        </div>
