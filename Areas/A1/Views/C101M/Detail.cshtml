                <!-- 專長/領域 Start -->
                <a name="academic_expertise" id="academic_"></a>
                <div id="Expertise" class="t-info-item" data-profile="academic_expertise">
                    <div class="t-panel bt-section-search">
                        <div class="t-panel-heading">
                            <i class="svg-icon svg-icon-2x" aria-hidden="true">
                                <svg>
                                    <use href="#ic-medal-star"></use>
                                </svg>
                            </i>
                            <div class="t-panel-heading-txt" data-title="EXPERTISE">專長/領域</div>
                        </div>
                        <div class="t-panel-main">
                            <div class="t-panel-main-fuild">
                                @*<ul><li class="t-timeline-item"></li></ul>*@
                                <div class="t-para" style="white-space: pre-line; width: 100%;">@Model.Detail.ExpertiseDesc</div>
                                <div class="teachers-list-item-lab-cobtainer" style="width: 100%;">
                                    <div class="t-label-list flex-row" style="word-wrap: break-word; white-space: normal;">
                                        @if (Model.Detail.Expertise_List.ToCount() > 0)
                                        {
                                            for (int j = 0; j < Model.Detail.Expertise_List.Length; j++)
                                            {
                                                var itemSub = Model.Detail.Expertise_List[j];
                                                if (itemSub.TONotNullString() == "") { continue; }
                                                var SubItemStyleColor = SubItemStyleColors[j % SubItemStyleColors.Length];
                                                <label class="t-badge t-badge-light-@SubItemStyleColor" data-bs-toggle="tooltip" aria-label="@itemSub" data-bs-placement="top">
                                                    @itemSub
                                                </label>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- 專長/領域 End -->
