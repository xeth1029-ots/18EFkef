    // 查詢清除
    function doSearchClear() {
        $('#Email').removeAttr('value');
        $('#TeacherName').removeAttr('value');
        $('#IDNO').removeAttr('value');
        $('#Keyword').removeAttr('value');
        $('#TeachUnit option').removeAttr('selected');
        $('#s_areaPicker1').removeAttr('value');
        $('#s_areaPicker2').removeAttr('value');
        $('#Industry option').removeAttr('selected');
    }

    // 查詢
    function doSearch() {
        blockUI();
        var form = $("form[id=main_form]");
        form.attr('action', '@Url.Action("Index", "C201M")').submit();
    }

    // 編輯
    function doEdit(Seq) {
        var data = { "Seq": Seq }
        var url = '@Url.Action("Edit", "C201M")?' + $.param(data);
        window.location = url;
    }

</script>
