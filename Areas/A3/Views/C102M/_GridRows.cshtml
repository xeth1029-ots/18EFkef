@using WKEFSERVICE.Models;
@using WKEFSERVICE.Areas.A3.Models;
@model C102MFormModel

@if (Model.Grid != null)
{
    for (int i = 0; i < Model.Grid.Count; i++)
    {
        var item = Model.Grid[i];
        @Html.HiddenFor(m => m.Grid[i].ROWID)
        @Html.HiddenFor(m => m.Grid[i].Year)
        @Html.HiddenFor(m => m.Grid[i].UnitCode)

        <tr>
            <td>@item.ROWID</td>
            <td>@item.Year_Name</td>
            <td>@item.DateS_Name</td>
            <td>@item.DateE_Name</td>
            <td align="left">
                <button type="button" class="btn btn-info" onclick="doUpd('@item.Year', '@item.UnitCode')">修改</button>
            </td>
        </tr>
    }
}