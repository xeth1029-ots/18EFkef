        $.ajax({
            url: "@Url.Action("FileDownloadLog", "Backend", new { area = "" })",
            data: { "Func": "AM/C902M", "Org": Org, "New": New },
            dataType: "json",
            method: "post",
            success: function (data) { },
            error: function (data) { }
        });
    }

    function CountFont(s) {
        const str_filter = /(\s)|(\n)/g;
        s = s.replace(str_filter, "");
        const utf8Data = new TextEncoder().encode(s);
        let p = 0;
        let counter = 0;
        while (p < utf8Data.length) {
            const first = utf8Data[p];
            counter += 1;
            if (first <= 0x7F) {
                p += 1;
            } else if (first <= 0xDF) {
                p += 2;
            } else if (first <= 0xEF) {
                p += 3;
            } else {
                p += 4;
            }
        }
        return counter;
    }

