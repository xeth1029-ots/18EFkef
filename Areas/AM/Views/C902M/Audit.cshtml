<script type="text/javascript">
    $(document).ready(function () {
        doJobAbilityDown();

        document.getElementById('Count_Detail_Effect').innerText = "字數統計：" + CountFont($("#Detail_Effect").val());
        document.getElementById('Count_Detail_PlanImprove').innerText = "字數統計：" + CountFont($("#Detail_PlanImprove").val());
        document.getElementById('Count_Detail_ExamImprove').innerText = "字數統計：" + CountFont($("#Detail_ExamImprove").val());
        document.getElementById('Count_Detail_materialsImprove').innerText = "字數統計：" + CountFont($("#Detail_materialsImprove").val());
    });

    function doBack() {
        blockUI();
        var form = $("form[id=main_form]");
        form.attr('action', '@Url.Action("Index")').submit();
    }

    //儲存-送出審核
    function doAudit() {
        //取得選中選項的值-取得選中選項的文字內容 通過:Y/不通過:N/退件修正:R;
        const AuditStatus_New_Value = $("#Detail_AuditStatus_New").find("option:selected").val();
        //const selectedText = selectedOption.text(); console.log(selectedText); // 選項 1 //console.log(selectedValue); // 1
        $('#Detail_AuditReason').val($('#Detail_AuditReason').val().trim());
        $('#Hid_Detail_AuditReason').val($('#Detail_AuditReason').val());
        if (AuditStatus_New_Value == "R" && $('#Detail_AuditReason').val() == "") {
            blockAlert("【審核狀態】選擇「退件修正」時，【退回原因說明】為必填。");
            return;
        }
        else if ($('#Detail_AuditReason').val() != "" && AuditStatus_New_Value != "R") {
            blockAlert("【退回原因說明】不為空，【審核狀態】必須選擇「退件修正」。");
            return;
        }

        blockConfirm("您確定要送出審核？", null, function () {
            var form = $("form[id=main_form]");
            form.attr('action', '@Url.Action("Save", "C902M")').submit();
        });
    }

    function doJobAbilityDown() {
        const tmpStr = "checkbox_Detail_CourseUnitCode_SHOW_" + $("#Detail_JobAbilityCode").val();
        //console.log(tmpStr);
        for (let item of document.getElementById("CourseUnitCode_SHOW").children) {
        //console.log(item.id);
            document.getElementById(item.id).style.display = "unset";
            if (tmpStr !== item.id.substring(0, item.id.length - 1)) {
                document.getElementById(item.id).style.display = "none";
            }
            document.getElementById(item.id).children[0].disabled = true;
        };
    }

