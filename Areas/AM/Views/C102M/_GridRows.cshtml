@using WKEFSERVICE.Models;
@using WKEFSERVICE.Areas.AM.Models;
@model C102MFormModel

@if (Model.Grid != null)
{
    for (int i = 0; i < Model.Grid.Count; i++)
    {
        var item = Model.Grid[i];
        @Html.HiddenFor(m => m.Grid[i].ROWID)
        @Html.HiddenFor(m => m.Grid[i].GRPID)
        @Html.HiddenFor(m => m.Grid[i].GRPNAME)
        <tr>
            <td>@item.ROWID</td>
            <td>@item.GRPID</td>
            <td>@item.GRPNAME</td>
            <td align="center">
                <button type="button" class="btn btn-info" onclick="doSetAuth('@item.GRPID')">權限</button>
            </td>
        </tr>
    }
}