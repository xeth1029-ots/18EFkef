@using WKEFSERVICE.Models;
@using WKEFSERVICE.Services;
@using WKEFSERVICE.DataLayers;
@using WKEFSERVICE.Areas.A2.Models;
@model C201MViewModel
@{
    /// <summary>注意！提示：此 A2/C201M 之語法取自 AM/C201M，並做功能性刪減</summary>
    Layout = "~/Views/Backend/_BackendMainLayout.cshtml";

    SessionModel sm = SessionModel.Get();

    string PicPath = (Model.Detail.Sex == "F") ? "~/assets_new/images/avastarPlaceholders-girl.svg" : "~/assets_new/images/avastarPlaceholders.svg";
    if (!string.IsNullOrEmpty(Model.Detail.SelfPicPath))
    {
        string picfile1 = string.Concat(new AMDAO().UploadPathTeacher, Model.Detail.SelfPicPath);
        if (File.Exists(Server.MapPath(picfile1))) { PicPath = picfile1; }
    }
    string svg10Ratio3 = "~/assets_new/images/10Ratio3.3333_v1.svg";

    string[] SubItemStyleColors = new string[] { "secondary", "primary", "tertiary", "quaternary", "success", "warning", "info" };
    string SexMark = (Model.Detail.Sex == "F" ? "♀" : "♂");
    string strPostCode = "";
    if (Model.Detail.PostalCode1.TONotNullString() != "") { strPostCode = Model.Detail.PostalCode1; }
    if (Model.Detail.PostalCode2.TONotNullString() != "") { strPostCode = string.Concat(strPostCode, "-", Model.Detail.PostalCode2); }
    if (strPostCode != "") { strPostCode = string.Concat("(", strPostCode, ") "); }
    string strChkTitle1 = "勾選前台顯示，代表同意該項個資公開揭露";
    string strPICFUTitle1 = "上傳檔案格式限定 JPG、PNG、GIF，檔案大小以 2MB 為限。";
    string strChkstyle1 = "margin-top: 10px; margin-right: 10px; width: 70px; height: 30px;";
    string strChkstyle2 = "margin-top: 10px; margin-right: 10px; width: 30px; height: 30px;";
}

<style>
    .t-teacher-page .t-wrapper-inner .t-panel .t-panel-item-cnt { padding-left: 0rem; }
    .t-form-label { min-width: 10rem; }
    .t-form-control { min-width: 15rem; }
</style>

@using (Html.BeginForm("Save", "C201M", FormMethod.Post, htmlAttributes: new { id = "main_form", @class = "form-horizontal", enctype = "multipart/form-data" }))
{
    @Html.HiddenFor(m => m.Detail.EditAreaIdx)
    @Html.HiddenFor(m => m.Detail.Seq)
    // for View
    @Html.HiddenFor(m => m.Detail.UnitName)
    @Html.HiddenFor(m => m.Detail.CombineName)
    @Html.HiddenFor(m => m.Detail.EduLevelHighest_Name)
    @Html.HiddenFor(m => m.Detail.EduLevel1_Name)
    @Html.HiddenFor(m => m.Detail.EduLevel2_Name)
    @Html.HiddenFor(m => m.Detail.EduLevel3_Name)
    @Html.HiddenFor(m => m.Detail.Expertise_Str)
    @Html.HiddenFor(m => m.Detail.TeachArea_Name)
    @Html.HiddenFor(m => m.Detail.IndustryStr)
    @Html.HiddenFor(m => m.Detail.Industry_Name)

    <section class="t-teacher-page" style="padding: unset; margin-bottom: 10rem;">
        <div class="container">
            <div class="t-wrapper-inner">
                <button type="button" class="btn btn--soft--dark btn--sm mr-2" onclick="doBack()" style="margin-bottom: 1rem;">
                    <i class="svg-icon mr-2" aria-hidden="true">
                        <svg>
                            <use href="#ic-arrow-l"></use>
                        </svg>
                    </i>
                    回上一頁
                </button>
                <!-- 師資介紹 Start -->
                <a name="academic_info" id="academic_info"></a>
                <div id="Info" class="t-info-item" data-profile="academic_info">
                    <div class="t-form-legend-info t-inline-flex" style="top: -3rem;">
                        <h3 class="t-inline-flex">師資介紹</h3>
                    </div>
                    <div class="t-panel bt-section-search">
                        <div id="Editor_1_BtnE" style="display: inline;">
                            <div id="edit-userInfo" class="t-panel-heading">
                                <a data-tu-inlineEditBtn="true" href="javascript:;" class="btn btn--primary" onclick="doEdit('1')">
                                    <i class="svg-icon"><svg><use href="#ic-edit"></use></svg></i>編輯
                                </a>
                            </div>
                        </div>
                        <div id="Editor_1_BtnS" style="display: none;">
                            <div id="edit-userInfo" class="t-panel-heading">
                                <a data-tu-inlineEditBtn="true" href="javascript:;" class="btn btn--danger" onclick="doSave('1')">
                                    <i class="svg-icon"><svg><use href="#ic-save"></use></svg></i>儲存
                                </a>
                            </div>
                        </div>
                        <div id="Editor_1_BtnC" style="display: none;">
                            <div id="edit-userInfo" class="t-panel-heading">
                                <a data-tu-inlineEditBtn="true" href="javascript:;" class="btn btn--dark" onclick="doCancel('1')" style="margin-right: 120px;">
                                    <i class="svg-icon"><svg><use href="#ic-redo"></use></svg></i>取消
                                </a>
                            </div>
                        </div>
                        <div class="t-panel-main" style="justify-content:unset; padding-left: 0rem; padding-right: 0rem; ">
                            <div class="mask mask-card-ruler"></div>
                            <div class="mask mask-brand-wda-logo-backgrounds"></div>
                            <div id="Editor_1_View" class="t-panel-item-cnt" style="display: inline; width: 100%;">
                                <div style="float: left; width: 300px">
                                    <div class="t-panel-item-img-container" style="width: unset;">
                                        <a class="t-panel-img t-img-overlay" data-fslightbox="gallery" href="@Url.Content(PicPath)">
                                            <picture>
                                                <source src="@Url.Content(PicPath)" data-src="@Url.Content(svg10Ratio3)">
                                                <img src="@Url.Content(PicPath)" alt="@Model.Detail.TeacherName" class="t-lazy-load" width="160" height="188" />
                                            </picture>
                                        </a>
                                    </div>
                                </div>
                                <div style="float: right; width: 700px">
                                    <dl class="t-definition-list">
                                        <dt class="t-definition-term" hidden>
                                            @Model.Detail.CombineName
                                        </dt>
                                        <dd class="t-definition-description ml-0">
                                            <div data-grad-under="info" class="t-panel-title">
                                                @Model.Detail.TeacherName
                                            </div>
                                            <div data-grad-under="secondary" class="t-panel-sub-title">
                                                @Model.Detail.TeacherEName
                                                &nbsp;
                                                @SexMark
                                                &nbsp;
                                            </div>
                                        </dd>
                                    </dl>
                                    <div class="t-panel-main-txt">
                                        前一年度授課總時數：<big>@Model.Detail.R1_THOURS_TRANSDATA_TOTAL</big> 小時
                                    </div>
                                    <ul class="t-list-txts mb-2">
                                        @if (Model.Detail.TeachJobAbilityDC.TONotNullString() == "Y")
                                        {
                                            <li class="t-list-txts-item">
                                                DC： <big class="t-fw-500">@Model.Detail.R2_THOURS_TRANSDATA_DC</big> 小時
                                            </li>
                                        }
                                        @if (Model.Detail.TeachJobAbilityBC.TONotNullString() == "Y")
                                        {
                                            <li class="t-list-txts-item">
                                                BC： <big class="t-fw-500">@Model.Detail.R2_THOURS_TRANSDATA_BC</big> 小時
                                            </li>
                                        }
                                        @if (Model.Detail.TeachJobAbilityKC.TONotNullString() == "Y")
                                        {
                                            <li class="t-list-txts-item">
                                                KC： <big class="t-fw-500">@Model.Detail.R2_THOURS_TRANSDATA_KC</big> 小時
                                            </li>
                                        }
                                        <li class="t-list-txts-item"><div>(當年度授課時數)</div></li>
                                        @*<li class="t-list-txts-item">DC： <big class="t-fw-500">0</big>小時</li>
                                            <li class="t-list-txts-item">BC： <big class="t-fw-500">0</big> 小時</li>
                                            <li class="t-list-txts-item">KC： <big class="t-fw-500">0</big> 小時</li>*@
                                    </ul>
                                    <dl class="t-definition-list">
                                        <dt class="t-definition-term">
                                            聯絡電話
                                        </dt>
                                        <dd data-tu-inlineEdit="true" data-tu-inlineEdit-label="聯絡電話" data-tu-inlineEdit-name="userInfo" data-tu-inlineEdit-id="UserPhone" data-tu-inlineEdit-placeholder="請輸入您的聯絡電話" class="t-definition-description">
                                            @Model.Detail.Tel
                                        </dd>
                                    </dl>
                                    <dl class="t-definition-list">
                                        <dt class="t-definition-term">
                                            聯絡手機
                                        </dt>
                                        <dd data-tu-inlineEdit="true" data-tu-inlineEdit-label="聯絡手機" data-tu-inlineEdit-name="userInfo" data-tu-inlineEdit-id="UserPhone" data-tu-inlineEdit-placeholder="請輸入您的聯絡手機" class="t-definition-description">
                                            @Model.Detail.Phone
                                        </dd>
                                    </dl>
                                    <dl class="t-definition-list">
                                        <dt class="t-definition-term">
                                            出生日期
                                        </dt>
                                        <dd data-tu-inlineEdit="true" data-tu-inlineEdit-label="出生日期" data-tu-inlineEdit-name="UserBirth" data-tu-inlineEdit-id="UserBirth" data-tu-inlineEdit-placeholder="請輸入您的出生日期" class="t-definition-description">
                                            @Model.Detail.Birthday
                                        </dd>
                                    </dl>
                                    <dl class="t-definition-list">
                                        <dt class="t-definition-term">
                                            電子郵件
                                        </dt>
                                        <dd class="t-definition-description">
                                            <a data-tu-inlineEdit="true" data-tu-inlineEdit-label="電子郵件" data-tu-inlineEdit-name="userInfo" data-tu-inlineEdit-id="UserMail" data-tu-inlineEdit-placeholder="請輸入您的電子郵件" @*href="mailto:"*@ title="@Model.Detail.Email" data-under="primary">
                                                @Model.Detail.Email
                                            </a>
                                        </dd>
                                    </dl>
                                    <dl class="t-definition-list">
                                        <dt class="t-definition-term t-relative">
                                            電子郵件 (工作)
                                        </dt>
                                        <dd class="t-definition-description">
                                            <a data-tu-inlineEdit="true" data-tu-inlineEdit-label="電子郵件" data-tu-inlineEdit-name="userInfo" data-tu-inlineEdit-id="UserMailWork" data-tu-inlineEdit-placeholder="請輸入您的電子郵件 " @*href="mailto:"*@ title="@Model.Detail.EmailWork" data-under="primary">
                                                @Model.Detail.EmailWork
                                            </a>
                                        </dd>
                                    </dl>
                                    <dl class="t-definition-list">
                                        <dt class="t-definition-term">
                                            聯絡地址
                                        </dt>
                                        <dd data-tu-inlineEdit="true" data-tu-inlineEdit-label="聯絡地址" data-tu-inlineEdit-name="userInfo" data-tu-inlineEdit-id="userAdress" data-tu-inlineEdit="true" data-tu-inlineEdit-placeholder="請輸入您的聯絡地址" class="t-definition-description">
                                            @strPostCode @Model.Detail.Address
                                        </dd>
                                    </dl>
                                </div>
                            </div>
                            <div id="Editor_1_Edit" class="bt-form-cnt" style="display: none;">
                                <div class="t-form t-txt-left">
                                    <div class="t-form-inline">
                                        <div class="t-form-group" title="@(strPICFUTitle1)">
                                            @Html.LabelFor(m => m.Detail.Pic_FILE, new { @class = "t-form-label" })
                                            @Html.TextBoxFor(m => m.Detail.Pic_FILE, new { type = "file", @class = "t-form-control", accept = ".jpg, .png, .jpeg, .gif, .bmp, .tif, .tiff" })
                                        </div>
                                        <div class="t-form-group">
                                            <a href="@(new AMDAO().UploadPathTeacher + Model.Detail.SelfPicPath)" download="@Model.Detail.SelfPicPath" title="點擊以下載 @Model.Detail.SelfPicPath" data-decoration-offset='4' data-decoration="underline" data-decoration-style='dotted'>
                                                @Model.Detail.SelfPicPath
                                            </a>
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">&nbsp;說明：@(strPICFUTitle1) &nbsp;</p>
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">*</p>
                                            @Html.LabelFor(m => m.Detail.TeacherName, new { @class = "t-form-label" })
                                            @Model.Detail.TeacherName
                                            @Html.HiddenFor(m => m.Detail.TeacherName)
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">&nbsp;</p>
                                            @Html.LabelFor(m => m.Detail.TeacherEName, new { @class = "t-form-label" })
                                            @Model.Detail.TeacherEName
                                            @Html.HiddenFor(m => m.Detail.TeacherEName)
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">*</p>
                                            @Html.LabelFor(m => m.Detail.Sex, new { @class = "t-form-label" })
                                            @Html.RadioButtonFor(m => m.Detail.Sex, "M", new { style = "margin-top: 10px; width: 30px; height: 30px; margin-right: 15px;" }) <p style="display: inline-block; margin-bottom: unset; margin-top: 10px;">男</p>
                                            @Html.RadioButtonFor(m => m.Detail.Sex, "F", new { style = "margin-top: 10px; width: 30px; height: 30px; margin-right: 15px; margin-left: 15px;" }) <p style="display: inline-block; margin-bottom: unset; margin-top: 10px;">女</p>
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">&nbsp;</p>
                                            @Html.LabelFor(m => m.Detail.Tel, new { @class = "t-form-label" })
                                            @Html.CheckBoxFor(m => m.Detail.IsShow_Tel, new { align = "left", style = strChkstyle1, @title = strChkTitle1 })
                                            @Html.LabelFor(m => m.Detail.IsShow_Tel, new { align = "left", style = "margin-top: 10px; margin-right: 10px;" })
                                            @Html.TextBoxFor(m => m.Detail.Tel, new { size = "30", maxlength = "30", @class = "t-form-control" })
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">&nbsp;</p>
                                            @Html.LabelFor(m => m.Detail.Phone, new { @class = "t-form-label" })
                                            @Html.CheckBoxFor(m => m.Detail.IsShow_Phone, new { align = "left", style = strChkstyle1, @title = strChkTitle1 })
                                            @Html.LabelFor(m => m.Detail.IsShow_Phone, new { align = "left", style = "margin-top: 10px; margin-right: 10px;" })
                                            @Html.TextBoxFor(m => m.Detail.Phone, new { size = "30", maxlength = "30", @class = "t-form-control" })
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">*</p>
                                            @Html.LabelFor(m => m.Detail.Birthday_AD, new { @class = "t-form-label" })
                                            @Html.CheckBoxFor(m => m.Detail.IsShow_Birthday, new { align = "left", style = strChkstyle1, @title = strChkTitle1 })
                                            @Html.LabelFor(m => m.Detail.IsShow_Birthday, new { align = "left", style = "margin-top: 10px; margin-right: 10px;" })
                                            @Html.DatePickerTWFor(m => m.Detail.Birthday_AD, new { @class = "t-form-control", placeholder = "YYY/MM/DD", style = "pointer-events:none;opacity:.66" })
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">*</p>
                                            @Html.LabelFor(m => m.Detail.Email, new { @class = "t-form-label" })
                                            @Html.CheckBoxFor(m => m.Detail.IsShow_Email, new { align = "left", style = strChkstyle1, @title = strChkTitle1 })
                                            @Html.LabelFor(m => m.Detail.IsShow_Email, new { align = "left", style = "margin-top: 10px; margin-right: 10px;" })
                                            @Html.TextBoxFor(m => m.Detail.Email, new { size = "999", maxlength = "64", @class = "t-form-control", style = "pointer-events:none;opacity:.66" })
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">&nbsp;</p>
                                            @Html.LabelFor(m => m.Detail.EmailWork, new { @class = "t-form-label" })
                                            @Html.CheckBoxFor(m => m.Detail.IsShow_EmailWork, new { align = "left", style = strChkstyle1, @title = strChkTitle1 })
                                            @Html.LabelFor(m => m.Detail.IsShow_EmailWork, new { align = "left", style = "margin-top: 10px; margin-right: 10px;" })
                                            @Html.TextBoxFor(m => m.Detail.EmailWork, new { size = "999", maxlength = "64", @class = "t-form-control" })
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">&nbsp;</p>
                                            @Html.LabelFor(m => m.Detail.Address, new { @class = "t-form-label" })
                                            @Html.CheckBoxFor(m => m.Detail.IsShow_Address, new { align = "left", style = strChkstyle2, @title = strChkTitle1 })
                                            @Html.LabelFor(m => m.Detail.IsShow_Address, new { align = "left", style = "margin-top: 10px; margin-right: 10px;" })
                                            @Html.TextBoxFor(m => m.Detail.PostalCode1, new { type = "number", maxlength = "3", @class = "t-form-control", style = "min-width:200px; width:200px" })&nbsp;-&nbsp;
                                            @Html.TextBoxFor(m => m.Detail.PostalCode2, new { type = "number", maxlength = "3", @class = "t-form-control", style = "min-width:200px; width:200px" })
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">&nbsp;</p>
                                            @Html.Label(" ", new { @class = "t-form-label" })
                                            @Html.TextBoxFor(m => m.Detail.Address, new { size = "999", maxlength = "200", @class = "t-form-control" })
                                        </div>
                                    </div>
                                    <br />
                                    <div class="t-form-inline">
                                        <div class="t-form-group">
                                            <p style="color:red">&nbsp;說明：@strChkTitle1 &nbsp;</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- 師資介紹 End -->
                <!-- 最高學歷 Start -->
                <a name="academic_highesteducation" id="academic_highesteducation"></a>
                <div id="Highest_Education" class="t-info-item" data-profile="academic_highesteducation">
                    <div class="t-panel bt-section-search" style="align-items: center;">
                        <div class="t-panel-heading">
                            <i class="svg-icon svg-icon-2x" aria-hidden="true">
                                <svg>
                                    <use href="#ic-education"></use>
                                </svg>
                            </i>
                            <div class="t-panel-heading-txt" data-title="HIGHEST EDUCATION">最高學歷</div>
                        </div>
                        <div id="Editor_2_View" class="t-panel-item-cnt" style="display: inline;">
                            <div class="t-panel-main">
                                <div class="t-panel-main-fuild">
                                    @Model.Detail.EduLevelHighest_Name
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- 最高學歷 End -->
                <!-- 學歷背景 Start -->
                <a name="academic_education" id="academic_education"></a>
                <div id="Education" class="t-info-item" data-profile="academic_education">
                    <div class="t-panel bt-section-search">
                        <div class="t-panel-heading">
                            <i class="svg-icon svg-icon-2x" aria-hidden="true">
                                <svg>
                                    <use href="#ic-education"></use>
                                </svg>
                            </i>
                            <div class="t-panel-heading-txt" data-title="EDUCATION">學歷背景</div>
                        </div>
                        <div id="Editor_3_View" class="t-panel-item-cnt" style="display: inline;">
                            <div class="t-panel-main">
                                <div class="t-panel-main-fuild">
                                    <ul class="t-timeline">
                                        @if (@Model.Detail.EduSchool1.TONotNullString() != "")
                                        {
                                            <li class="t-timeline-item">
                                                <div class="t-timeline-marker"></div>
                                                <div class="t-timeline-content">
                                                    <div class="t-timeline-title">@Model.Detail.EduSchool1</div>
                                                    <ul class="t-list-txts">
                                                        <li class="t-list-txts-item">@Model.Detail.EduDept1</li>
                                                        <li class="t-list-txts-item">@Model.Detail.EduLevel1_Name</li>
                                                    </ul>
                                                </div>
                                            </li>
                                        }
                                        @if (@Model.Detail.EduSchool2.TONotNullString() != "")
                                        {
                                            <li class="t-timeline-item">
                                                <div class="t-timeline-marker"></div>
                                                <div class="t-timeline-content">
                                                    <div class="t-timeline-title">@Model.Detail.EduSchool2</div>
                                                    <ul class="t-list-txts">
                                                        <li class="t-list-txts-item">@Model.Detail.EduDept2</li>
                                                        <li class="t-list-txts-item">@Model.Detail.EduLevel2_Name</li>
                                                    </ul>
                                                </div>
                                            </li>
                                        }
                                        @if (@Model.Detail.EduSchool3.TONotNullString() != "")
                                        {
                                            <li class="t-timeline-item">
                                                <div class="t-timeline-marker"></div>
                                                <div class="t-timeline-content">
                                                    <div class="t-timeline-title">@Model.Detail.EduSchool3</div>
                                                    <ul class="t-list-txts">
                                                        <li class="t-list-txts-item">@Model.Detail.EduDept3</li>
                                                        <li class="t-list-txts-item">@Model.Detail.EduLevel3_Name</li>
                                                    </ul>
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- 學歷背景 End -->
                <!-- 服務單位/職稱 Start -->
                <a name="academic_employment " id="academic_employment"></a>
                <div id="Employment" class="t-info-item" data-profile="academic_employment">
                    <div class="t-panel bt-section-search">
                        <div class="t-panel-heading">
                            <i class="svg-icon svg-icon-2x" aria-hidden="true">
                                <svg>
                                    <use href="#ic-briefcase"></use>
                                </svg>
                            </i>
                            <div class="t-panel-heading-txt" data-title="EMPLOYMENT HISTORY">服務單位/職稱</div>
                        </div>
                        <div id="Editor_4_BtnE" style="display: inline;">
                            <div id="edit-userInfo" class="t-panel-heading">
                                <a data-tu-inlineEditBtn="true" href="javascript:;" class="btn btn--primary" onclick="doEdit('4')">
                                    <i class="svg-icon"><svg><use href="#ic-edit"></use></svg></i>編輯
                                </a>
                            </div>
