<script type="text/javascript">
    var sizeLimitMax = 2097152; //2*1024*1024
    $("#Detail_Pic_FILE").on("change", function () {
        if(!checkFile1(sizeLimitMax)){ return; }
    });

    let isEdit = false;
    $(document).ready(function () {
        isEdit = false;
        @* 不為空白時，表示是之前儲存失敗，因此要還原該區塊的編輯狀態 *@
        var Idx = $("#Detail_EditAreaIdx").val();
        if (Idx != "") { doEdit(Idx); }
        //alert(Idx);
        $("#ExpertiseCode_SHOW div").attr("style", "float:left;width:350px;");
    });

    @*var citysJson = "@Url.Action("JsonFiles1", "Home", new { area = "" })";*@
    var citysJson = decodeURIComponent("%2FHome%2FJsonFiles1");
    var industryJson = "@Url.Action("GetJsonIndustry", "C201M")";
    document.addEventListener("DOMContentLoaded", function () {
        var picker1 = new JsCategoryPicker('s_areaPicker1', {
            id: 'areaPicker1', // Picker ID
            data: citysJson, // 代入縣市資訊
            dataArray: ["CTID", "CTNAME"], // 只接受兩個 目前還沒寫擴充
            dataArraySub: ["ZIPCODE", "ZIPNAME"], // 只接受兩個 目前還沒寫擴充
            prefix: 'city1_',
            prefixSub: 'dist1_',
            selectAll: true, // 二層選單是否要開啟第一個全選 預設 false
            title: '地區類別選單',
        });
        var IndustryPicker = new JsCategoryPicker('IndustryPicker', {
            id: 'TheIndustryPicker',
            data: industryJson,
            dataArray: ["MSTID", "MSTNAME"],
            dataArraySub: ["DETID", "DETNAME"],
            prefix: 'mst1_',
            prefixSub: 'det1_',
            selectAll: false,  // 沒作用
            title: '授課產業別選單',
        });
    });

    //上傳檔案檢核
    function checkFile1(sizeLimit) {
        //sizeLimit單位:byte
        if($("#Detail_Pic_FILE").val()==""){ return true; }
        let fileType = "." + document.getElementById("Detail_Pic_FILE").value.replace(/^.*[\\\/]/, '').split('.').pop().toLowerCase();
        let acceptType = document.getElementById("Detail_Pic_FILE").accept.toLowerCase();
        //console.log(fileType);
        //console.log(acceptType);
        //console.log(acceptType.indexOf(fileType));
        if (acceptType.indexOf(fileType) === -1) {
            blockAlert("請選擇正確的檔案格式！ (" + acceptType + ")");
            document.getElementById("Detail_Pic_FILE").value = null;
            return false;
        }
        const fileInput = document.querySelector('input[type="file"]');
        const file = fileInput.files[0];
        const fileSize = Math.round(file.size / 1024 / 1024);
        const fileSizeLimit = Math.round(sizeLimit / 1024 / 1024);
        //console.log('fileSize : ' + fileSize);
        //console.log('fileSizeLimit : ' + fileSizeLimit);
        if (fileSize > fileSizeLimit) {
            blockAlert('您所選擇的檔案大小為 ' + fileSize + 'MB，超過了上傳上限! (檔案大小限制' + fileSizeLimit + 'MB以下)\n不允許上傳！');
            document.getElementById("Detail_Pic_FILE").value = null;
            //document.getElementById("Detail_Pic_FILE").outerHTML = '<input accept=".jpg, .png, .jpeg, .gif, .bmp, .tif, .tiff" class="t-form-control" id="Detail_Pic_FILE" name="Detail.Pic_FILE" type="file" value="">';
            return false;
        }
        return true;
    }

    // 回上一頁
    function doBack() {
        window.location = "@Url.Content("~/Backend/")";
    }

    // 按鈕 個別區塊 編輯
    function doEdit(Idx) {
        if (isEdit === true) {
            alert("請先結束編輯狀態，再進行操作！");
            return;
        }
        document.getElementById("Editor_" + Idx + "_BtnE").style.display = 'none';  // Hide
        document.getElementById("Editor_" + Idx + "_View").style.display = 'none';  // Hide
        document.getElementById("Editor_" + Idx + "_BtnS").style.display = 'inline';  // Show
        document.getElementById("Editor_" + Idx + "_Edit").style.display = 'inline';  // Show
        document.getElementById("Editor_" + Idx + "_BtnC").style.display = 'inline';  // Show
        isEdit = true;
    }

    // 按鈕 個別區塊 取消
    function doCancel(Idx) {
        document.getElementById("Editor_" + Idx + "_BtnE").style.display = 'inline';  // Show
        document.getElementById("Editor_" + Idx + "_View").style.display = 'inline';  // Show
        document.getElementById("Editor_" + Idx + "_BtnS").style.display = 'none';  // Hide
        document.getElementById("Editor_" + Idx + "_Edit").style.display = 'none';  // Hide
        document.getElementById("Editor_" + Idx + "_BtnC").style.display = 'none';  // Hide
        isEdit = false;
        @* 因修改儲存欄位與顯示欄位共用，若未必填儲存失敗返還且按下取消時，會導致顯示空白異常問題，故用重整方式修正 (偷吃步) *@
        if ($("#Detail_EditAreaIdx").val() != "") {
            var data = { "Seq": $("#Detail_Seq").val() }
            var url = '@Url.Action("Edit", "C201M")?' + $.param(data);
            window.location = url;
        }
    }

    // 按鈕 個別區塊 儲存
    function doSave(Idx) {
        if(Idx=='1' && $("#Detail_Pic_FILE").val()!="" && !checkFile1(sizeLimitMax) ){ return; }
        $("#Detail_EditAreaIdx").val(Idx);
        blockUI();
        var form = $("form[id=main_form]");
        form.attr('action', '@Url.Action("Save", "C201M")').submit();
    }
</script>