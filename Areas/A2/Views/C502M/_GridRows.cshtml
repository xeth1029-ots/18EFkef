@using WKEFSERVICE.Models
@using WKEFSERVICE.Services
@using WKEFSERVICE.DataLayers
@using WKEFSERVICE.Areas.A2.Models
@model C502MFormModel

@if (Model.Grid != null)
{
    for (int i = 0; i < Model.Grid.Count; i++)
    {
        var item = Model.Grid[i];
        @Html.HiddenFor(x => x.Grid[i].ROWID)
        @Html.HiddenFor(x => x.Grid[i].Seq)
        @Html.HiddenFor(x => x.Grid[i].AuditStatus)

        bool isCanEdt = (item.AuditStatus.TONotNullString() == "" || item.AuditStatus.TONotNullString() == " " || item.AuditStatus.TONotNullString() == "R");
        bool isCanDel = (item.AuditStatus.TONotNullString() == "" || item.AuditStatus.TONotNullString() == " ");

        <tr>
            <td>@item.ROWID</td>
            <td>@item.Year_Name</td>
            <td>@item.FirstTime_Name</td>
            <td>@item.JobAbilityCode</td>
            <td>@item.UpdatedDatetime_Name</td>
            <td>@item.AuditStatus_Name</td>
            <td align="center">
                @if (isCanEdt)
                {
                    <button type="button" class="btn btn-info" onclick="doUpd('@item.Seq')">修改</button>
                }
                else
                {
                    <button type="button" class="btn btn-info" onclick="doUpd('@item.Seq')">檢視</button>
                }
                @if (isCanDel)
                {
                    <button type="button" class="btn btn-info" onclick="doDel('@item.Seq', '@item.ROWID')" style="color: white; background-color: #dc3545;">刪除</button>
                }
                <button type="button" class="btn btn-info" onclick="doPDF('@item.Seq')" style="color: white; background-color: #007bff;">列印</button>
            </td>
        </tr>
    }
}